+++ b/dadb-android/src/main/kotlin/dadb/android/wireless/WirelessDebugPairing.kt
@@ -0,0 +1,232 @@
+package dadb.android.wireless
+
+import dadb.AdbKeyPair
+import dadb.android.tls.AdbTlsContexts
+import java.io.DataInputStream
+import java.io.DataOutputStream
+import java.net.InetSocketAddress
+import java.net.Socket
+import java.nio.ByteBuffer
+import java.nio.ByteOrder
+import javax.net.ssl.SSLSocket
+
+/**
+ * Stable app-facing contract for Wireless Debugging pairing.
+ *
+ * The current implementation keeps parity with the old app-side experimental flow so the pairing
+ * logic can live under `external/dadb`. A future native SPAKE2-backed implementation can replace
+ * [ExperimentalWirelessDebugPairingClient] without changing callers.
+ */
+interface WirelessDebugPairingClient {
+    fun pair(request: WirelessDebugPairingRequest): Result<WirelessDebugPairingResult>
+}
+
+data class WirelessDebugPairingRequest(
+    val host: String,
+    val port: Int,
+    val pairingCode: String,
+)
+
+data class WirelessDebugPairingResult(
+    val host: String,
+    val port: Int,
+    val peerPublicKey: ByteArray? = null,
+)
+
+/**
+ * Temporary pairing client migrated out of the app layer.
+ *
+ * This preserves the existing experimental flow while making the `dadb-android` module the
+ * single place that owns Wireless Debugging transport and wire protocol glue.
+ */
+class ExperimentalWirelessDebugPairingClient(
+    private val keyPair: AdbKeyPair,
+    private val tlsSocketFactory: WirelessDebugTlsSocketFactory = WirelessDebugTlsSocketFactory(keyPair),
+) : WirelessDebugPairingClient {
+    override fun pair(request: WirelessDebugPairingRequest): Result<WirelessDebugPairingResult> {
+        var socket: Socket? = null
+        var sslSocket: SSLSocket? = null
+
+        return runCatching {
+            val connectedSocket =
+                Socket().also { raw ->
+                raw.connect(InetSocketAddress(request.host, request.port), CONNECT_TIMEOUT_MS)
+                }
+            socket = connectedSocket
+
+            val connectedTlsSocket = tlsSocketFactory.create(connectedSocket, request.host, request.port)
+            sslSocket = connectedTlsSocket
+
+            val streams =
+                PairingStreams(
+                    input = DataInputStream(connectedTlsSocket.inputStream),
+                    output = DataOutputStream(connectedTlsSocket.outputStream),
+                )
+            val protocol = ExperimentalWirelessDebugPairingProtocol(keyPair.adbPublicKey())
+
+            protocol.sendPeerInfo(streams.output)
+            val peerInfo = protocol.receivePeerInfo(streams.input)
+            protocol.sendPairingRequest(streams.output, request.pairingCode)
+
+            val response = protocol.receivePairingResponse(streams.input)
+            if (response.status != ExperimentalWirelessDebugPairingProtocol.STATUS_SUCCESS) {
+                throw IllegalStateException("Wireless Debugging pairing failed: status=${response.status}")
+            }
+
+            WirelessDebugPairingResult(
+                host = request.host,
+                port = request.port,
+                peerPublicKey = peerInfo.publicKey,
+            )
+        }.also {
+            runCatching { sslSocket?.close() }
+            runCatching { socket?.close() }
+        }
+    }
+
+    companion object {
+        private const val CONNECT_TIMEOUT_MS = 5000
+    }
+}
+
+class WirelessDebugTlsSocketFactory(
+    keyPair: AdbKeyPair,
+) {
+    private val sslSocketFactory = AdbTlsContexts.create(keyPair).socketFactory
+
+    fun create(
+        socket: Socket,
+        host: String,
+        port: Int,
+    ): SSLSocket =
+        (sslSocketFactory.createSocket(socket, host, port, true) as SSLSocket).also {
+            it.useClientMode = true
+            it.startHandshake()
+        }
+}
+
+private class ExperimentalWirelessDebugPairingProtocol(
+    private val adbPublicKey: ByteArray,
+) {
+    fun sendPeerInfo(output: DataOutputStream) {
+        val payload =
+            ByteBuffer
+                .allocate(4 + adbPublicKey.size)
+                .order(ByteOrder.LITTLE_ENDIAN)
+                .putInt(adbPublicKey.size)
+                .put(adbPublicKey)
+                .array()
+
+        sendPacket(output, MSG_PEER_INFO, payload)
+    }
+
+    fun receivePeerInfo(input: DataInputStream): PeerInfo {
+        val packet = receivePacket(input)
+        if (packet.type != MSG_PEER_INFO) {
+            throw IllegalStateException("Expected PEER_INFO, got ${packet.type}")
+        }
+
+        val buffer = ByteBuffer.wrap(packet.payload).order(ByteOrder.LITTLE_ENDIAN)
+        val publicKeySize = buffer.int
+        if (publicKeySize !in 0..packet.payload.size - 4) {
+            throw IllegalStateException("Invalid peer public key size: $publicKeySize")
+        }
+        val publicKey = ByteArray(publicKeySize)
+        buffer.get(publicKey)
+        return PeerInfo(publicKey)
+    }
+
+    fun sendPairingRequest(
+        output: DataOutputStream,
+        pairingCode: String,
+    ) {
+        val codeBytes = pairingCode.toByteArray(Charsets.UTF_8)
+        val payload =
+            ByteBuffer
+                .allocate(4 + codeBytes.size)
+                .order(ByteOrder.LITTLE_ENDIAN)
+                .putInt(codeBytes.size)
+                .put(codeBytes)
+                .array()
+
+        sendPacket(output, MSG_PAIRING_REQUEST, payload)
+    }
+
+    fun receivePairingResponse(input: DataInputStream): PairingResponse {
+        val packet = receivePacket(input)
+        if (packet.type != MSG_PAIRING_RESPONSE) {
+            throw IllegalStateException("Expected PAIRING_RESPONSE, got ${packet.type}")
+        }
+
+        val buffer = ByteBuffer.wrap(packet.payload).order(ByteOrder.LITTLE_ENDIAN)
+        return PairingResponse(status = buffer.int)
+    }
+
+    private fun sendPacket(
+        output: DataOutputStream,
+        type: Int,
+        payload: ByteArray,
+    ) {
+        val header =
+            ByteBuffer
+                .allocate(PAIRING_PACKET_HEADER_SIZE)
+                .order(ByteOrder.LITTLE_ENDIAN)
+                .put(type.toByte())
+                .put(0.toByte())
+                .putInt(payload.size)
+                .array()
+
+        output.write(header)
+        output.write(payload)
+        output.flush()
+    }
+
+    private fun receivePacket(input: DataInputStream): Packet {
+        val header = ByteArray(PAIRING_PACKET_HEADER_SIZE)
+        input.readFully(header)
+
+        val buffer = ByteBuffer.wrap(header).order(ByteOrder.LITTLE_ENDIAN)
+        val type = buffer.get().toInt()
+        buffer.get()
+        val payloadSize = buffer.int
+
+        if (payloadSize !in 0..PAIRING_PACKET_MAX_PAYLOAD_SIZE) {
+            throw IllegalStateException("Invalid payload size: $payloadSize")
+        }
+
+        val payload = ByteArray(payloadSize)
+        if (payloadSize > 0) {
+            input.readFully(payload)
+        }
+
+        return Packet(type = type, payload = payload)
+    }
+
+    companion object {
+        private const val PAIRING_PACKET_HEADER_SIZE = 6
+        private const val PAIRING_PACKET_MAX_PAYLOAD_SIZE = 2048
+        private const val MSG_PEER_INFO = 0
+        private const val MSG_PAIRING_REQUEST = 1
+        private const val MSG_PAIRING_RESPONSE = 2
+
+        const val STATUS_SUCCESS = 0
+    }
+}
+
+private data class PairingStreams(
+    val input: DataInputStream,
+    val output: DataOutputStream,
+)
+
+private data class Packet(
+    val type: Int,
+    val payload: ByteArray,
+)
+
+data class PeerInfo(
+    val publicKey: ByteArray,
+)
+
+data class PairingResponse(
+    val status: Int,
+)
